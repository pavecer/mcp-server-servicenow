# Local-only folder: scratch scripts, credentials notes, temp files
local/
logs/

# Private documentation (internal implementation details, deployment notes, test results)
# Move sensitive internal docs here: non-public architecture, deployment runbooks, internal reviews
.private-docs/
.private-notes/

# HTTP Archive files from browser testing (may contain tokens, cookies, auth headers)
*.har

# Personal helper scripts (not part of the published toolchain)
find_urls.ps1

# Copilot Studio per-developer connection bindings (regenerated by `pac copilot init`).
# These contain TenantId / EnvironmentId / AccountEmail / AgentId for the dev who pulled the agent.
copilot-studio/**/.mcs/conn.json
